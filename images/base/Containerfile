# Base image for sandbox-agent guest VMs.
# Provides: sshd, bash, git, ip, mount, curl, GNU coreutils/findutils/grep/sed/awk.
FROM cgr.dev/chainguard/wolfi-base:latest

RUN apk add --no-cache \
    dropbear \
    bash \
    git \
    ca-certificates-bundle \
    iproute2 \
    coreutils \
    findutils \
    grep \
    sed \
    gawk \
    curl

# Ensure /usr/local/bin exists (not present in Wolfi by default)
RUN mkdir -p /usr/local/bin

# Generate dropbear host keys
RUN mkdir -p /etc/dropbear /root/.ssh && \
    chmod 700 /root/.ssh && \
    dropbearkey -t ecdsa -f /etc/dropbear/dropbear_ecdsa_host_key && \
    dropbearkey -t ed25519 -f /etc/dropbear/dropbear_ed25519_host_key
